# Partner App QA Automation Framework Configuration

# Environment Settings
ENVIRONMENT=staging
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_CONSOLE_LOGGING=true

# Database Configuration
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=qa_user
DATABASE_PASSWORD=qa_password
DATABASE_NAME=partner_app
DATABASE_POOL_SIZE=10
DATABASE_POOL_ECHO=false

# Appium Configuration
APPIUM_SERVER_URL=http://appium:4723
APPIUM_TIMEOUT=30
APPIUM_IMPLICIT_WAIT=10
APPIUM_EXPLICIT_WAIT=20
APPIUM_DEVICE_NAME=emulator-5554
APPIUM_PLATFORM=Android

# For pre-installed apps (use app_package and app_activity)
APPIUM_APP_PACKAGE=com.partnerapp
APPIUM_APP_ACTIVITY=.MainActivity

# For local app files (use app_path)
# Example: APPIUM_APP_PATH=C:\apps\partner_app.apk
APPIUM_APP_PATH="C:\Users\NidhiChaure\Downloads\app-release 1.apk"

# Additional Appium settings
APPIUM_AUTOMATION_NAME=UiAutomator2
APPIUM_UDID=ZD222LB46C
APPIUM_RECORD_VIDEO=false

# Playwright Configuration
PLAYWRIGHT_BROWSER_TYPE=chromium
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=0
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_VIEWPORT_WIDTH=1920
PLAYWRIGHT_VIEWPORT_HEIGHT=1080
PLAYWRIGHT_RECORD_VIDEO=false
PLAYWRIGHT_RECORD_TRACE=false

# API Configuration
API_BASE_URL=http://localhost:8080
API_TIMEOUT=30
API_RETRY_COUNT=3
API_RETRY_DELAY=1
API_VERIFY_SSL=true

# Reporting Configuration
ALLURE_DIR=reports/allure
HTML_DIR=reports/html
SCREENSHOT_DIR=screenshots
VIDEO_DIR=videos
LOGS_DIR=logs
ENABLE_ALLURE=true
ENABLE_HTML=true
CAPTURE_SCREENSHOT_EACH_STEP=true
CAPTURE_VIDEO_EACH_SCENARIO=true
SLACK_ENABLED=false
SLACK_WEBHOOK=
EMAIL_ENABLED=false
EMAIL_RECIPIENTS=

# Execution Configuration
PARALLEL_WORKERS=4
TEST_TIMEOUT=300
HEADLESS_MODE=true
CAPTURE_SCREENSHOT_ON_FAILURE=true
CAPTURE_VIDEO_ON_FAILURE=true

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2

# Test Data
TEST_DATA_DIR=test_data
